{
  "name": "mcp-ai-ml-api",
  "version": "1.0.0",
  "description": "MCP server for the AIML API — TTS, image generation, and video generation",
  "type": "module",
  "bin": {
    "mcp-ai-ml-api": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "start:http": "node --env-file=.env dist/index.js --http",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
